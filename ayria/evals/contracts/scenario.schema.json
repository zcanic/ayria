{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ayria eval scenario",
  "type": "object",
  "required": [
    "scenario_id",
    "scenario_version",
    "purpose",
    "runtime_mode",
    "provider",
    "model",
    "config_overrides",
    "steps",
    "scoring"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "scenario_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "purpose": {
      "type": "string"
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["stub", "live"]
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "mock_profile": {
      "type": ["string", "null"]
    },
    "config_overrides": {
      "type": "object"
    },
    "fixture_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "scoring": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/score_rule"
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["step_id", "kind"],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "kind": {
          "type": "string",
          "enum": ["http_request", "world_state_seed", "delay"]
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT"]
        },
        "path": {
          "type": "string",
          "pattern": "^/api/v1/"
        },
        "payload": {
          "type": "object"
        },
        "fixture_ref": {
          "type": "string"
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "http_request" } }
          },
          "then": {
            "required": ["method", "path"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "delay" } }
          },
          "then": {
            "required": ["delay_ms"]
          }
        }
      ]
    },
    "score_rule": {
      "type": "object",
      "required": ["rule_id", "type", "target"],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "exact_match",
            "substring_match",
            "schema_match",
            "policy_assertion",
            "latency_budget"
          ]
        },
        "target": {
          "type": "string",
          "pattern": "^steps\\.[A-Za-z_][A-Za-z0-9_]*\\."
        },
        "expected": {},
        "schema": {
          "type": "object"
        },
        "max_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "enum": ["exact_match", "substring_match", "policy_assertion"] } }
          },
          "then": {
            "required": ["expected"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "schema_match" } }
          },
          "then": {
            "required": ["schema"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "latency_budget" } }
          },
          "then": {
            "required": ["max_ms"]
          }
        }
      ]
    }
  }
}
