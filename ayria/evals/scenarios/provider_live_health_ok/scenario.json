{
  "scenario_id": "provider_live_health_ok",
  "scenario_version": "v1",
  "purpose": "Verify that provider inventory and provider health endpoints report a truthful healthy live local provider state.",
  "runtime_mode": "live",
  "provider": "ollama",
  "model": "qwen3.5:0.8b",
  "config_overrides": {},
  "fixture_refs": [],
  "steps": [
    {
      "step_id": "get_providers",
      "kind": "http_request",
      "method": "GET",
      "path": "/api/v1/providers",
      "payload": {}
    },
    {
      "step_id": "get_provider_health",
      "kind": "http_request",
      "method": "GET",
      "path": "/api/v1/health/providers",
      "payload": {}
    }
  ],
  "scoring": [
    {
      "rule_id": "providers_live_mode",
      "type": "exact_match",
      "target": "steps.get_providers.response_body.runtime_mode",
      "expected": "live"
    },
    {
      "rule_id": "providers_ollama_id",
      "type": "exact_match",
      "target": "steps.get_providers.response_body.items[0].id",
      "expected": "ollama"
    },
    {
      "rule_id": "providers_ollama_status",
      "type": "substring_match",
      "target": "steps.get_providers.response_body.items[0].status",
      "expected": "ok"
    },
    {
      "rule_id": "health_ollama_id",
      "type": "exact_match",
      "target": "steps.get_provider_health.response_body.providers[0].id",
      "expected": "ollama"
    },
    {
      "rule_id": "health_ollama_status",
      "type": "substring_match",
      "target": "steps.get_provider_health.response_body.providers[0].status",
      "expected": "ok"
    }
  ]
}
